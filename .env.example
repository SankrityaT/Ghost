# Your iMessage phone number (the one this Mac is signed into)
MY_PHONE=+1234567890

# Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_...

# How many minutes before Ghost nudges you about an unreplied message (default: 60)
# Urgent messages (like "are you okay?") get nudged 4x faster automatically.
GHOST_THRESHOLD_MINUTES=60

# How often Ghost scans for unreplied messages in minutes (default: 15)
SCAN_INTERVAL_MINUTES=15
